# Convex DEPLOYMENT env (the application secrets), applied automatically by the
# in-stack `deployer` service via `convex env set`. Copy to .env.convex
# (gitignored), fill EVERY CHANGE_ME, and keep it safe. The deployer refuses to
# run while any CHANGE_ME remains.
#
# Generate 32-byte secrets with: openssl rand -hex 32
# ACCOUNT_ID_PEPPER is SET ONCE: changing it invalidates every account number.

SESSION_SIGNING_KEY=CHANGE_ME_hex32
ADMIN_SESSION_SIGNING_KEY=CHANGE_ME_hex32
# You paste this in the browser to register the first admin passkey (step 4).
ADMIN_BOOTSTRAP_SECRET=CHANGE_ME_hex32
IP_HASH_SALT=CHANGE_ME_hex32
ACCOUNT_ID_PEPPER=CHANGE_ME_hex32

# Cloudflare Turnstile (from the Turnstile dashboard for beta.freesocks.org).
TURNSTILE_SECRET_KEY=CHANGE_ME_turnstile_secret
TURNSTILE_SITE_KEY=CHANGE_ME_turnstile_site_key

# WebAuthn (admin passkeys) bound to the beta domain.
WEBAUTHN_RP_ID=beta.freesocks.org
WEBAUTHN_ORIGIN=https://beta.freesocks.org

# Production posture: Secure cookies + trust Caddy's X-Forwarded-For.
ENVIRONMENT=production
TRUSTED_PROXY=true
# Leave CF_FRONTED unset behind Caddy: there's no Cloudflare edge, so a
# client-supplied cf-connecting-ip would be spoofable. Set it to true ONLY with
# a real CF edge in front AND the origin locked to CF-only traffic.
# CF_FRONTED=true

# Optional: seed the first Remnawave instance at cutover (else add it in the
# admin CMS -> Backend servers). The slug becomes "remnawave-primary".
# REMNAWAVE_BASE_URL=https://panel.example.org
# REMNAWAVE_API_TOKEN=CHANGE_ME_remnawave_token

# Renew/upgrade callout links (surfaced in /api/v1/config). Lapsed/expiring
# members are pointed at DONATE_URL with CONTACT_URL as the secondary CTA.
DONATE_URL=https://unredacted.org/donate
CONTACT_URL=https://unredacted.org/contact

# Optional extras (uncomment as needed):
# WEBHOOK_SIGNING_SECRET=CHANGE_ME_hex32
# FREE_TIER_DAILY_CAP is gone: the free-account daily cap is now the
# admin-tunable `freetier.create` rate-limit policy (default 3), edited in the
# admin CMS -> Rate limits without a redeploy.
# FREE_TIER_EXPIRY_DAYS=90
