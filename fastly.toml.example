# Fastly Compute service manifest. Copy to `fastly.toml`, fill in the
# values marked <PLACEHOLDER>, and run `fastly compute publish` to deploy.
# See `docs/fastly-setup.md` for the full operator walkthrough.

manifest_version = 3
name             = "freesocks-control-plane"
description      = "FreeSocks control plane on Fastly Compute (alternative to Cloudflare Workers)"
language         = "javascript"

# Authors are surfaced on the Fastly dashboard; replace with your team's
# contact if you fork.
authors          = ["ops@example.org"]

# Entry script. The build pipeline compiles `src-entries/fastly.ts` →
# `bin/main.wasm` and Fastly serves it.
[scripts]
  build      = "bun run build:fastly"

# === Backends ===
# Every external host the compute service `fetch`es from must be declared as
# a backend with a TLS-validated upstream config. Add additional entries for
# any non-default S3 mirror provider you configure.
[local_server.backends.remnawave]
  url             = "https://<PLACEHOLDER-remnawave-host>"
  override_host   = "<PLACEHOLDER-remnawave-host>"

[local_server.backends.authentik]
  url             = "https://<PLACEHOLDER-authentik-host>"
  override_host   = "<PLACEHOLDER-authentik-host>"

[local_server.backends.civicrm]
  url             = "https://<PLACEHOLDER-civicrm-host>"
  override_host   = "<PLACEHOLDER-civicrm-host>"

[local_server.backends.turso]
  # Turso/libSQL HTTP endpoint. Find this in the Turso dashboard under
  # "Database HTTP URL" — looks like `https://<db-name>-<org>.turso.io`.
  url             = "https://<PLACEHOLDER-turso-host>.turso.io"
  override_host   = "<PLACEHOLDER-turso-host>.turso.io"

[local_server.backends.turnstile]
  url             = "https://challenges.cloudflare.com"
  override_host   = "challenges.cloudflare.com"

[local_server.backends.resend]
  # Only required if EMAIL_PROVIDER=resend.
  url             = "https://api.resend.com"
  override_host   = "api.resend.com"

# === Local-dev KV store fixtures ===
# Mirrors the production KV bindings. The Fastly local server uses these to
# back `new KVStore('name')` calls during `fastly compute serve`. Production
# stores are created via the Fastly UI or `fastly kv-store create`.
[local_server.kv_stores]
  FS_SESSIONS_KV = []
  FS_CACHE_KV    = []
  FS_RATELIMIT_KV = []

# === Local-dev config + secret store fixtures ===
[local_server.config_stores.fs_config]
  format = "inline-toml"
  [local_server.config_stores.fs_config.contents]
    ENVIRONMENT                  = "development"
    REMNAWAVE_BASE_URL           = "https://<PLACEHOLDER-remnawave-host>"
    AUTHENTIK_ISSUER             = "https://<PLACEHOLDER-authentik-host>/application/o/freesocks/"
    AUTHENTIK_CLIENT_ID          = "<PLACEHOLDER>"
    AUTHENTIK_REDIRECT_URI       = "https://app.freesocks.local/api/auth/callback"
    AUTHENTIK_SCOPES             = "openid email profile"
    CIVICRM_API_BASE             = "https://<PLACEHOLDER-civicrm-host>/civicrm/ajax/api4"
    EMAIL_PROVIDER               = "resend"
    EMAIL_FROM                   = "noreply@freesocks.example"
    FREE_TIER_TURNSTILE_SITE_KEY = "<PLACEHOLDER-turnstile-site-key>"
    FREE_TIER_DAILY_CAP          = "1"
    FREE_TIER_EXPIRY_DAYS        = "90"
    SUBSCRIPTION_DEFAULT_FORMAT  = "auto"
    S3_MIRRORS_ENABLED           = "false"
    WEBAUTHN_RP_ID               = "freesocks.local"
    WEBAUTHN_RP_NAME             = "FreeSocks"
    WEBAUTHN_ORIGIN              = "https://app.freesocks.local"
    WEBHOOKS_CIVICRM_ENABLED     = "false"
    MEMBERS_JOIN_URL             = "https://members.unredacted.org/join"
    MEMBERS_ACCOUNT_URL          = "https://members.unredacted.org/account"
    TURSO_DATABASE_URL           = "libsql://<PLACEHOLDER-turso-host>.turso.io"

[local_server.secret_stores.fs_secrets]
  format = "inline-toml"
  [local_server.secret_stores.fs_secrets.contents]
    REMNAWAVE_API_TOKEN         = "<PLACEHOLDER>"
    AUTHENTIK_CLIENT_SECRET     = "<PLACEHOLDER>"
    CIVICRM_API_KEY             = "<PLACEHOLDER>"
    RESEND_API_KEY              = "<PLACEHOLDER>"
    SESSION_SIGNING_KEY         = "<PLACEHOLDER>"
    ADMIN_SESSION_SIGNING_KEY   = "<PLACEHOLDER>"
    ADMIN_BOOTSTRAP_SECRET      = "<PLACEHOLDER>"
    IP_HASH_SALT                = "<PLACEHOLDER>"
    TURNSTILE_SECRET_KEY        = "<PLACEHOLDER>"
    CRON_TRIGGER_SECRET         = "<PLACEHOLDER>"
    TURSO_AUTH_TOKEN            = "<PLACEHOLDER>"
