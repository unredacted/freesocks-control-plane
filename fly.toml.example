# Example Fly.io config for self-hosting the FreeSocks Control Plane on Bun.
# Copy to fly.toml, fill in app name + region, then `fly launch --no-deploy` to
# create the volume, set secrets, then `fly deploy`.
#
# IMPORTANT: this is the *self-host* path. The Cloudflare Workers path
# (`bun run deploy:prod` against wrangler.toml) is recommended for production
# unless you have a specific reason to host elsewhere (e.g. compliance, region
# restrictions, total Cloudflare avoidance).

app = "freesocks-control-plane"
primary_region = "sjc"   # pick the region nearest your user base

[build]
  dockerfile = "Dockerfile"

[env]
  PORT = "3000"
  SQLITE_PATH = "/data/freesocks.sqlite"
  ENVIRONMENT = "production"
  LOG_LEVEL = "info"
  EMAIL_PROVIDER = "resend"   # cloudflare binding unavailable off-Workers
  # ... other public vars (REMNAWAVE_BASE_URL, AUTHENTIK_*, CIVICRM_API_BASE,
  #     FREE_TIER_TURNSTILE_SITE_KEY, WEBAUTHN_*, etc.)
  # Mirror what's in wrangler.toml [vars].

[[mounts]]
  source = "freesocks_data"
  destination = "/data"

[http_service]
  internal_port = 3000
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 1

  [http_service.checks]
    [[http_service.checks.health]]
      grace_period = "10s"
      interval = "30s"
      method = "get"
      path = "/api/healthz"
      timeout = "5s"

[[vm]]
  memory = "512mb"
  cpu_kind = "shared"
  cpus = 1

# Secrets (set via `fly secrets set NAME=value`):
#   SESSION_SIGNING_KEY, ADMIN_SESSION_SIGNING_KEY, ADMIN_BOOTSTRAP_SECRET,
#   IP_HASH_SALT, TURNSTILE_SECRET_KEY, REMNAWAVE_API_TOKEN,
#   AUTHENTIK_CLIENT_SECRET, CIVICRM_API_KEY, RESEND_API_KEY,
#   WEBHOOK_CIVICRM_HMAC_SECRET, S3_PROVIDER_<N>_ACCESS_KEY_ID/SECRET_ACCESS_KEY
