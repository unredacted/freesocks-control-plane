{
  "name": "freesocks-control-plane",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "FreeSocks Control Plane - self-hosted Convex backend + Svelte SPA, account-number member auth",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "concurrently -k -n convex,vite \"convex dev\" \"vite\"",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:codegen": "convex codegen",
    "selfhost:up": "docker compose -f self-hosted/docker-compose.yml --env-file self-hosted/.env up -d",
    "selfhost:down": "docker compose -f self-hosted/docker-compose.yml --env-file self-hosted/.env down",
    "selfhost:admin-key": "docker compose -f self-hosted/docker-compose.yml exec backend ./generate_admin_key.sh",
    "selfhost:env": "bash scripts/selfhost-env.sh",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc -b --noEmit && tsc -p convex/tsconfig.json --noEmit && svelte-check --workspace . --threshold error"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/inter-tight": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/svelte-query": "^6.1.29",
    "@tanstack/svelte-query-devtools": "^6.1.29",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "convex": "^1.40.0",
    "qrcode": "^1.5.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.16.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "bits-ui": "^2.18.1",
    "bun-types": "^1.3.14",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "runed": "^0.37.1",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "svelte-sonner": "^1.1.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
